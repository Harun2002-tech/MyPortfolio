# Firebase (Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Brevo (https://app.brevo.com/settings/keys/api)
# Sender must be a verified sender/domain in Brevo.
VITE_BREVO_API_KEY=YOUR_BREVO_API_KEY
VITE_BREVO_SENDER_EMAIL=your-sender@example.com
VITE_BREVO_RECEIVER_EMAIL=your-receiver@example.com
